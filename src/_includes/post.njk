---
layout: base.njk
---
<article class="post">
  <div class="post-header">
    <div class="post-date">{{ date | date("MMMM d, yyyy") }}</div>
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-author">By {{ author }}</div>
  </div>
  {% if image %}<img class="post-image" src="{{ image }}" alt="{{ title }}">{% endif %}
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  {% if image %}"image": {{ image | dump | safe }},{% endif %}
  "datePublished": "{{ date | date('yyyy-MM-dd') }}",
  "author": { "@type": "Organization", "name": {{ author | dump | safe }} },
  "publisher": { "@type": "Organization", "name": "Leadforce Solutions" }
}
</script>
